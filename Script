-- Auto PCLD Anti Kick
local antiKickPCLDActive = false
local currentGold = nil
local activePCLDLoop = false
local fixedPCLD = nil

local function autoScanPCLD()
    local nearest = nil; local shortestDist = math.huge
    local char = Player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    for _, v in pairs(workspace:GetChildren()) do
        if v.Name:find("PlayerCharacterLocationDetector") and v:IsA("BasePart") then
            local dist = (v.Position - hrp.Position).Magnitude
            if dist < shortestDist then shortestDist = dist; nearest = v end
        end
    end
    fixedPCLD = nearest; return nearest
end

DefenseExtra:CreateToggle({
    Name     = "Auto PCLD Anti Kick",
    Flag     = "AutoPCLDAntiKick",
    Default  = false,
    Callback = function(Value)
        SetToggleState("AutoPCLDAntiKick", Value)
        antiKickPCLDActive = Value
        if not Value then
            activePCLDLoop = false
            if currentGold then
                pcall(function() ReplicatedStorage.MenuToys.DestroyToy:FireServer(currentGold) end)
                currentGold = nil
            end
            return
        end
        local char = Player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            fixedPCLD = autoScanPCLD()
            if not fixedPCLD then
                Library:Notify({Title = "Silenced Hub", Content = "Error: No PCLD found!", Duration = 4})
                return
            end
            task.spawn(function()
                local spawnPos = fixedPCLD.CFrame * CFrame.new(0, 2, 0)
