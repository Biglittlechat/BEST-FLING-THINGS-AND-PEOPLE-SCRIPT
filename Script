                    local kunai = inv2 and inv2:FindFirstChild("NinjaShuriken")
                    if not kunai then
                        kunai = SpawnToyAK("NinjaShuriken")
                        if kunai == nil then continue end
                        kunai.Name = "AntiKick"
                    end
                    repeat
                        if kunai and kunai:FindFirstChild("StickyPart") and kunai.StickyPart.CanTouch == true then
                            StickKunai(kunai)
                            kunai.Name = "AntiKick"
                        end
                        task.wait(0.3)
                    until not kunai or not _G.ShurikenAntiKick or not kunai:FindFirstChild("StickyPart") or kunai.StickyPart.CanTouch == false
                    if not kunai or not kunai:FindFirstChild("StickyPart") then ClearKunai() end
                end
            end)
        else
            _G.ShurikenAntiKick = false
            ClearKunai()
        end
    end
})

